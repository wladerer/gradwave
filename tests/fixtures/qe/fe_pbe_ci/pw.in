&control
  calculation = 'scf'
  prefix = 'fe_pbe_ci'
  pseudo_dir = '../pseudos'
  outdir = './tmp'
  verbosity = 'high'
/
&system
  ibrav = 0
  nat = 1
  ntyp = 1
  ecutwfc = 60.0
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.0073498649
  nspin = 2
  starting_magnetization(1) = 0.4
  nbnd = 12
/
&electrons
  conv_thr = 1.0d-10
/
ATOMIC_SPECIES
Fe 55.845 Fe_ONCV_PBE-1.2.upf
CELL_PARAMETERS angstrom
-1.435 1.435 1.435
1.435 -1.435 1.435
1.435 1.435 -1.435
ATOMIC_POSITIONS crystal
Fe 0.00 0.00 0.00
K_POINTS automatic
6 6 6 0 0 0
