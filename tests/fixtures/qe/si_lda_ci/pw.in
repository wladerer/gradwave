&control
  calculation = 'scf'
  prefix = 'si_lda_ci'
  pseudo_dir = '../pseudos'
  outdir = './tmp'
  verbosity = 'high'
/
&system
  ibrav = 0
  nat = 2
  ntyp = 1
  ecutwfc = 15.0
  input_dft = 'sla+pw+nogx+nogc'
  occupations = 'fixed'
/
&electrons
  conv_thr = 1.0d-12
/
ATOMIC_SPECIES
Si 28.0855 Si_ONCV_PBE-1.2.upf
CELL_PARAMETERS angstrom
0.000 2.715 2.715
2.715 0.000 2.715
2.715 2.715 0.000
ATOMIC_POSITIONS crystal
Si 0.00 0.00 0.00
Si 0.25 0.25 0.25
K_POINTS automatic
2 2 2 0 0 0
