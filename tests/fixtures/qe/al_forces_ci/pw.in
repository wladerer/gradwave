&control
  calculation = 'scf'
  prefix = 'al_forces_ci'
  tprnfor = .true.
  pseudo_dir = '../pseudos'
  outdir = './tmp'
  verbosity = 'high'
/
&system
  ibrav = 0
  nat = 4
  ntyp = 1
  ecutwfc = 20.0
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.0073498649
  nbnd = 32
/
&electrons
  conv_thr = 1.0d-12
/
ATOMIC_SPECIES
Al 26.9815 Al_ONCV_PBE-1.2.upf
CELL_PARAMETERS angstrom
4.05 0.00 0.00
0.00 4.05 0.00
0.00 0.00 4.05
ATOMIC_POSITIONS crystal
Al 0.03 0.02 -0.015
Al 0.00 0.50 0.50
Al 0.50 0.00 0.50
Al 0.50 0.50 0.00
K_POINTS automatic
2 2 2 0 0 0
