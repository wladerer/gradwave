&control
  calculation = 'scf'
  prefix = 'al_stress'
  pseudo_dir = '../pseudos'
  outdir = './tmp'
  verbosity = 'high'
  tstress = .true.
  tprnfor = .true.
/
&system
  ibrav = 0
  nat = 1
  ntyp = 1
  ecutwfc = 20.0
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.0073498649
  nbnd = 10
/
&electrons
  conv_thr = 1.0d-12
/
ATOMIC_SPECIES
Al 26.9815 Al_ONCV_PBE-1.2.upf
CELL_PARAMETERS angstrom
0.0121500000 2.0331000000 2.0209500000
2.0088000000 0.0121500000 2.0209500000
2.0209500000 2.0452500000 0.0000000000
ATOMIC_POSITIONS crystal
Al 0.00 0.00 0.00
K_POINTS automatic
4 4 4 0 0 0
