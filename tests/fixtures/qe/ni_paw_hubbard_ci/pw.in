&control
  calculation = 'scf'
  prefix = 'nihub'
  pseudo_dir = '.'
  outdir = './tmp'
  verbosity = 'high'
/
&system
  ibrav = 0
  nat = 1
  ntyp = 1
  ecutwfc = 50.0
  ecutrho = 400.0
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.0073498649
  nbnd = 18
  nspin = 2
  starting_magnetization(1) = 0.5
/
&electrons
  conv_thr = 1.0d-10
  mixing_beta = 0.3
/
ATOMIC_SPECIES
Ni 58.6934 Ni.pbe-spn-kjpaw_psl.1.0.0.UPF
CELL_PARAMETERS angstrom
0.000 1.760 1.760
1.760 0.000 1.760
1.760 1.760 0.000
ATOMIC_POSITIONS angstrom
Ni 0.0000 0.0000 0.0000
K_POINTS automatic
4 4 4 0 0 0
HUBBARD (atomic)
U Ni-3d 3.0
