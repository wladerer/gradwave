&control
  calculation = 'scf'
  prefix = 'cu_pbe_ci'
  pseudo_dir = '../pseudos'
  outdir = './tmp'
  verbosity = 'high'
/
&system
  ibrav = 0
  nat = 1
  ntyp = 1
  ecutwfc = 40.0
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.0073498649
  nbnd = 16
/
&electrons
  conv_thr = 1.0d-12
/
ATOMIC_SPECIES
Cu 63.546 Cu_ONCV_PBE-1.2.upf
CELL_PARAMETERS angstrom
0.0000 1.8075 1.8075
1.8075 0.0000 1.8075
1.8075 1.8075 0.0000
ATOMIC_POSITIONS crystal
Cu 0.00 0.00 0.00
K_POINTS automatic
2 2 2 0 0 0
