&control
  calculation = 'scf'
  prefix = 'nio'
  outdir = './tmp'
  pseudo_dir = '../pseudos'
  verbosity = 'high'
/
&system
  ibrav = 0
  nat = 4
  ntyp = 3
  ecutwfc = 45.0
  nbnd = 40
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.003675
  nspin = 2
  starting_magnetization(1) = 0.5
  starting_magnetization(2) = -0.5
  starting_magnetization(3) = 0.0
/
&electrons
  conv_thr = 1.0d-8
  mixing_beta = 0.3
  electron_maxstep = 200
/
ATOMIC_SPECIES
  Ni1  58.69  PD_Ni_PBE.upf
  Ni2  58.69  PD_Ni_PBE.upf
  O    16.00  PD_O_PBE.upf
CELL_PARAMETERS angstrom
   2.085   2.085   4.170
   2.085   4.170   2.085
   4.170   2.085   2.085
ATOMIC_POSITIONS crystal
  Ni1  0.00  0.00  0.00
  Ni2  0.50  0.50  0.50
  O    0.25  0.25  0.25
  O    0.75  0.75  0.75
K_POINTS automatic
  2 2 2 0 0 0
HUBBARD (atomic)
  U Ni1-3d 5.0
  U Ni2-3d 5.0
