&control
  calculation = 'scf'
  prefix = 'gaas_pbe_ci'
  pseudo_dir = '../pseudos'
  outdir = './tmp'
  verbosity = 'high'
/
&system
  ibrav = 0
  nat = 2
  ntyp = 2
  ecutwfc = 30.0
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.0014699725
  nbnd = 13
/
&electrons
  conv_thr = 1.0d-12
/
ATOMIC_SPECIES
Ga 69.723 Ga_ONCV_PBE-1.2.upf
As 74.922 As_ONCV_PBE-1.2.upf
CELL_PARAMETERS angstrom
0.0000 2.8265 2.8265
2.8265 0.0000 2.8265
2.8265 2.8265 0.0000
ATOMIC_POSITIONS crystal
Ga 0.00 0.00 0.00
As 0.25 0.25 0.25
K_POINTS automatic
2 2 2 0 0 0
