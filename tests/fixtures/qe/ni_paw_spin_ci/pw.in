&control
  calculation = 'scf'
  prefix = 'ni_paw'
  pseudo_dir = '../pseudos'
  outdir = './tmp'
  verbosity = 'high'
/
&system
  ibrav = 0
  nat = 1
  ntyp = 1
  ecutwfc = 50.0
  ecutrho = 400.0
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.0073498649
  nbnd = 18
  nspin = 2
  starting_magnetization(1) = 0.5
/
&electrons
  conv_thr = 1.0d-12
/
ATOMIC_SPECIES
Ni 58.6934 Ni.pbe-spn-kjpaw_psl.1.0.0.UPF
CELL_PARAMETERS angstrom
0.000 1.760 1.760
1.760 0.000 1.760
1.760 1.760 0.000
ATOMIC_POSITIONS crystal
Ni 0.00 0.00 0.00
K_POINTS automatic
4 4 4 0 0 0
